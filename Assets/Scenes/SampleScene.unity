  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "The movement vectors change according to your camera. \nTry pressing W/Z
    and then rotating the camera to get a better understanding.\n\nAll mechanics
    require a good timing.\n\nBounce: While nearly idle, press the space button whenever
    you hit a plane / floor.\n\nClimbing: When next to a \"Climbing Wall\", press
    the space button to climb repetitively to climb it.\n\nWall - to - Wall jumps:
    When between or next to this walls, press the space button while aiming at a
    direction using the movement keys to throw yourself there in high speed."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_fontSharedMaterials: []
  m_fontMaterial: {fileID: 0}
